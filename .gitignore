####
# One .gitignore at repo root only. No nested .gitignore unless from a git
# submodule. Sections: KiCad, FreeCAD, VSCode, STM32CubeIDE, Python, Inbox.
####

####
# BEGIN KICAD
####

# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Archived backups (KiCad 6.0+)
**/*-backups/*.zip

# Local history snapshots (KiCad automatic backups — machine-local, contains nested .git)
.history/

# Zip archives (derived artifacts — commit individual Gerbers/BOM/placement files instead)
*.zip

# Local project settings (per-machine view state)
*.kicad_prl

# ERC and DRC reports (processed into design-rule-waivers.md; do not commit raw reports)
*.rpt

# Override: track everything inside production/ directories (Gerbers, BOM, placement),
# netlist files stored alongside the schematic for firmware/design review reference,
# and schematic PDF exports committed alongside the schematic source.
!electrical/**/production/
!electrical/**/production/**
!electrical/**/*.net
!electrical/**/*.pdf
# Inside production/: commit only the fab-deliverable zip and BOM.
# Loose gerbers / drill files / drill maps are deleted by kicad-export-gerbers.sh after
# being packaged into the zip; ignoring them defends against half-finished runs
# accidentally committing stray artifacts.
electrical/**/production/*.gbr
electrical/**/production/*.gbrjob
electrical/**/production/*.drl
electrical/**/production/*-drl_map.pdf
# Re-ignore LibreOffice/OpenOffice lock files inside production/
electrical/**/production/.~lock.*#

# LibreOffice/OpenOffice lock files (created while a file is open)
.~lock.*#

####
# END KICAD
####

####
# BEGIN FREECAD
####

# Lock file created while a project is open
*.FC.lock

# Backup files created by FreeCAD
*.FCBak
*.FCStd[0-9]
*.FCStd[0-9][0-9]

####
# END FREECAD
####

####
# BEGIN VSCODE
####

# Machine-specific workspace settings
.vscode/

####
# END VSCODE
####

####
# BEGIN STM32CUBEIDE / CMAKE FIRMWARE
####

# Build output directories (CMake, per-configuration CubeIDE)
build/
Debug/
Release/

# Dependency files (generated by GCC -MMD)
*.d

# Object files
*.o
*.ko
*.obj

# Linked output
*.elf
*.hex
*.bin
*.map
*.ilk
*.exp
*.lst

# Stack usage files (generated by GCC -fstack-usage)
*.su

# Static and shared libraries (build outputs, not sources)
*.a
*.la
*.lo
*.so
*.so.*
*.dll
*.dylib

# Eclipse/CubeIDE workspace metadata (machine-specific, not project config)
.metadata/

# NOTE: .ioc, .project, .cproject, and *.ld linker scripts should be committed —
# they define project structure and are not regenerated by a clean build.

####
# END STM32CUBEIDE / CMAKE FIRMWARE
####

####
# BEGIN PYTHON
####

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Sphinx documentation
docs/_build/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Virtual environments (root .venv for project-servicing tooling, and each
# software/<app>/.venv and firmware/<board>/.venv)
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# PDM
.pdm-python
.pdm-build/

# pixi
.pixi

# PEP 582
__pypackages__/

# mypy / pyre / pytype
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Cython debug symbols
cython_debug/

# Ruff
.ruff_cache/

# PyPI
.pypirc

####
# END PYTHON
####

####
# BEGIN INBOX
####

# Drop zone for unprocessed files (receipts, invoices, datasheets, anything the
# agent is asked to examine). May contain PII — never commit. The directory
# itself is kept by .gitkeep.
inbox/*
!inbox/.gitkeep

####
# END INBOX
####

####
# AGENT TOOLING
####

# Claude Code: personal, per-machine permissions + state — never commit.
# A tracked .claude/settings.json (shared project config) is fine to commit.
.claude/settings.local.json

####
# END AGENT TOOLING
####
